# .env.example — EAD Enterprise Suite MCP Server
# Auto-generated by @suite/generator. Do not edit.
# Copy to .env and fill in the values before running the server.

# Authentication — exactly one flow must be configured.

# Flow 1: Email / password
# description: Your GoCertius account email address
# isSecret: false
MCP_AUTH_EMAIL=

# description: Your GoCertius account password
# isSecret: true
MCP_AUTH_PASSWORD=

# Flow 2: OpenID Connect (alternative to email/password)
# description: OpenID Connect issuer URL
# isSecret: false
MCP_OPENID_ISSUER=

# description: OpenID Connect client ID
# isSecret: false
MCP_OPENID_CLIENT_ID=

# description: OpenID Connect refresh token
# isSecret: true
MCP_OPENID_REFRESH_TOKEN=

# Transport (optional)
# description: HTTP port when running in hosted (HTTP) mode; ignored in stdio mode
# isSecret: false
PORT=8080
