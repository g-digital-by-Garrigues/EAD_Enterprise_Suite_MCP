# .env.example — EAD Enterprise Suite MCP Server
# Auto-generated by @suite/generator. Do not edit.
# Copy to .env and fill in the values before running the server.

# Authentication — configure EXACTLY ONE of the 2 flows below.
# They are alternatives, so no single variable is globally required and all
# are marked isRequired:false.

# Email + password
# description: Your EAD Enterprise Suite account email. Configure exactly one flow; do not combine it with the others.
# isSecret: false
# isRequired: false
MCP_AUTH_EMAIL=

# description: Your EAD Enterprise Suite account password.
# isSecret: true
# isRequired: false
MCP_AUTH_PASSWORD=

# User key — a long-lived key, exchanged automatically for a short-lived session token
# description: Long-lived EAD Enterprise Suite user key, exchanged automatically for a short-lived session token. Use it for headless or automated access instead of an account password. Configure exactly one flow; do not combine it with the others.
# isSecret: true
# isRequired: false
MCP_AUTH_USER_KEY=

# Inbound Bearer verification (HTTP mode only) — NOT an auth flow and not an
# alternative to the credentials above. Leave empty unless you host this server
# over HTTP and want it to verify the tokens its callers present.
# description: RFC 7662 token introspection URL for inbound Bearer verification in HTTP mode. Opt-in, and required when MCP_HTTP_PUBLIC=true. Leave empty for stdio (local) use.
# isSecret: false
# isRequired: false
MCP_SVC_INTROSPECT_URL=

# description: Client ID this server presents to the introspection endpoint above (its resource-server credentials). Only needed alongside MCP_SVC_INTROSPECT_URL; it does not authenticate you to EAD Enterprise Suite.
# isSecret: false
# isRequired: false
MCP_SVC_CLIENT_ID=

# description: Client secret this server presents to the introspection endpoint above (its resource-server credentials). Only needed alongside MCP_SVC_INTROSPECT_URL; it does not authenticate you to EAD Enterprise Suite.
# isSecret: true
# isRequired: false
MCP_SVC_CLIENT_SECRET=

# API base URL (optional — every tool has a working built-in default)
# description: Overrides the default upstream API host for every tool
# isSecret: false
# isRequired: false
MCP_API_BASE_URL=
# Transport (optional)
# description: HTTP port when running in hosted (HTTP) mode; ignored in stdio mode
# isSecret: false
# isRequired: false
PORT=8080

# description: Interface the HTTP transport binds to. Default 127.0.0.1 (localhost only). Set 0.0.0.0 to expose on all interfaces (containers do this automatically).
# isSecret: false
# isRequired: false
MCP_HTTP_HOST=127.0.0.1

# description: Comma-separated allowed browser Origins (DNS-rebinding defense). Empty = reject any request carrying an Origin header; non-browser clients (CLI/SDK) send no Origin and are always allowed. Use '*' to allow all.
# isSecret: false
# isRequired: false
MCP_ALLOWED_ORIGINS=

# description: Comma-separated allowed Host headers. Empty = Host validation disabled (default). When set, requests with a Host outside the list are rejected.
# isSecret: false
# isRequired: false
MCP_ALLOWED_HOSTS=

# description: Set to "true" for public/multi-tenant deployments. Activates Host validation and refuses to start unless (1) MCP_ALLOWED_ORIGINS or MCP_ALLOWED_HOSTS is set AND (2) inbound Bearer introspection is configured (MCP_SVC_INTROSPECT_URL + MCP_SVC_CLIENT_ID/SECRET) or MCP_ALLOW_UNVERIFIED_BEARER=true is set explicitly (fail-closed).
# isSecret: false
# isRequired: false
MCP_HTTP_PUBLIC=

# description: Escape hatch for MCP_HTTP_PUBLIC=true WITHOUT inbound-token introspection: set to "true" ONLY when an upstream gateway already verifies Bearer tokens. The server logs a prominent warning and forwards tokens upstream unverified.
# isSecret: false
# isRequired: false
MCP_ALLOW_UNVERIFIED_BEARER=

# description: Maximum accepted POST /mcp request-body size in bytes (default 16777216 = 16 MiB — sized so base64 file uploads within the documented tool limits fit). Oversized requests get a 413 JSON-RPC error before/while reading — closes a memory-exhaustion DoS vector in public deployments. Note: base64 file sources are capped by this limit BEFORE MCP_FILE_MAX_BYTES applies.
# isSecret: false
# isRequired: false
MCP_HTTP_MAX_BODY_BYTES=

# description: Set to "true" to allow plain http:// fileUrl downloads in evidence_create (default https-only). Private/internal addresses are rejected regardless (resolution-time check; see the documented DNS TOCTOU limitation in the hosted-deployment runbook).
# isSecret: false
# isRequired: false
MCP_ALLOW_INSECURE_FILE_URL=
